{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Pyramid",
  "version": "1.0.0",
  "identifier": "com.solitairesuite.pyramid",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "windows": [
      {
        "title": "Pyramid",
        "url": "pyramid/index.html",
        "width": 1000,
        "height": 720,
        "minWidth": 820,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": { "csp": null },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "dmg", "deb", "appimage"],
    "category": "Game",
    "shortDescription": "Pyramid Solitaire",
    "longDescription": "Pyramid solitaire — pair cards summing to 13 to clear the pyramid.",
    "icon": [
      "icons/pyramid/32x32.png",
      "icons/pyramid/128x128.png",
      "icons/pyramid/128x128@2x.png",
      "icons/pyramid/icon.icns",
      "icons/pyramid/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/pyramid/icon.ico",
        "installMode": "perMachine",
        "displayLanguageSelector": false
      }
    },
    "macOS": { "minimumSystemVersion": "10.13" }
  }
}
