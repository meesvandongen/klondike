{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Hearts",
  "version": "1.0.0",
  "identifier": "com.solitairesuite.hearts",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Hearts",
        "url": "hearts/index.html",
        "width": 1180,
        "height": 860,
        "minWidth": 980,
        "minHeight": 720,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": { "csp": null },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "dmg", "deb", "appimage"],
    "category": "Game",
    "shortDescription": "Hearts",
    "longDescription": "Hearts — avoid hearts and the Queen of Spades. Lowest total wins.",
    "icon": [
      "icons/hearts/32x32.png",
      "icons/hearts/128x128.png",
      "icons/hearts/128x128@2x.png",
      "icons/hearts/icon.icns",
      "icons/hearts/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/hearts/icon.ico",
        "installMode": "perMachine",
        "displayLanguageSelector": false
      }
    },
    "macOS": { "minimumSystemVersion": "10.13" }
  }
}
