{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FreeCell",
  "version": "1.0.0",
  "identifier": "com.solitairesuite.freecell",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "FreeCell",
        "url": "freecell/index.html",
        "width": 1180,
        "height": 900,
        "minWidth": 980,
        "minHeight": 740,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": { "csp": null },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "dmg", "deb", "appimage"],
    "category": "Game",
    "shortDescription": "FreeCell Solitaire",
    "longDescription": "FreeCell solitaire — almost every deal is solvable.",
    "icon": [
      "icons/freecell/32x32.png",
      "icons/freecell/128x128.png",
      "icons/freecell/128x128@2x.png",
      "icons/freecell/icon.icns",
      "icons/freecell/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/freecell/icon.ico",
        "installMode": "perMachine",
        "displayLanguageSelector": false
      }
    },
    "macOS": { "minimumSystemVersion": "11.0" }
  }
}
