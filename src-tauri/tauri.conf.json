{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Klondike",
  "version": "1.0.0",
  "identifier": "com.klondike.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "windows": [
      {
        "title": "Klondike",
        "width": 1024,
        "height": 740,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "dmg", "deb", "appimage"],
    "category": "Game",
    "shortDescription": "Klondike Solitaire",
    "longDescription": "A classic Klondike Solitaire game styled after the Windows Vista edition.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installMode": "perMachine",
        "displayLanguageSelector": false
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.13"
    }
  }
}
