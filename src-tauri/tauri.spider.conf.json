{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Spider",
  "version": "1.0.0",
  "identifier": "com.solitairesuite.spider",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Spider",
        "url": "spider/index.html",
        "width": 1280,
        "height": 920,
        "minWidth": 1100,
        "minHeight": 760,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": { "csp": null },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "dmg", "deb", "appimage"],
    "category": "Game",
    "shortDescription": "Spider Solitaire",
    "longDescription": "Spider solitaire (1-suit) — build eight K-to-A sequences to win.",
    "icon": [
      "icons/spider/32x32.png",
      "icons/spider/128x128.png",
      "icons/spider/128x128@2x.png",
      "icons/spider/icon.icns",
      "icons/spider/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/spider/icon.ico",
        "installMode": "perMachine",
        "displayLanguageSelector": false
      }
    },
    "macOS": { "minimumSystemVersion": "10.13" }
  }
}
