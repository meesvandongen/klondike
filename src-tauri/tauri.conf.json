{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Klondike",
  "version": "1.0.0",
  "identifier": "com.solitairesuite.klondike",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Klondike",
        "url": "klondike/index.html",
        "width": 1100,
        "height": 880,
        "minWidth": 880,
        "minHeight": 720,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "dmg", "deb", "appimage"],
    "category": "Game",
    "shortDescription": "Klondike Solitaire",
    "longDescription": "Classic Klondike Solitaire styled after the Windows Vista edition.",
    "icon": [
      "icons/klondike/32x32.png",
      "icons/klondike/128x128.png",
      "icons/klondike/128x128@2x.png",
      "icons/klondike/icon.icns",
      "icons/klondike/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/klondike/icon.ico",
        "installMode": "perMachine",
        "displayLanguageSelector": false
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.13"
    }
  }
}
